[Unit]
Description=Ollama qwen2.5-coder (saved qwen-32k)
After=network.target ollama.service
Wants=ollama.service

[Service]
User=devuser
Environment=HOME=/home/devuser
WorkingDirectory=/home/devuser
ExecStart=/usr/local/bin/ollama run qwen-32k
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
