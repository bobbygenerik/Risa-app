<?xml version="1.0" encoding="utf-8"?>
<!-- MoviesScreen.xml - Movies browsing screen with modern Netflix-style UI -->
<component name="MoviesScreen" extends="Group">
    <interface>
        <field id="visible" type="boolean" value="false" onChange="onVisibleChange" />
        <field id="xtreamServer" type="string" />
        <field id="xtreamUsername" type="string" />
        <field id="xtreamPassword" type="string" />
        <field id="movieSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/MoviesScreen.brs" />
    
    <children>
        <!-- Background gradient -->
        <Rectangle id="background" width="1920" height="1080" color="0x050710FF" />
        <Rectangle width="1920" height="540" translation="[0,540]" color="0x0d1140FF" />
        
        <!-- Hero section -->
        <Group id="heroSection" translation="[40,20]">
            <!-- Hero container -->
            <Rectangle id="heroBg" width="1840" height="420" color="0x1a1a2eFF" />
            
            <!-- Hero background image -->
            <Poster id="heroImage" width="1840" height="420" loadDisplayMode="scaleToZoom" />
            
            <!-- Dark overlay -->
            <Rectangle width="1840" height="420" color="0x00000066" />
            
            <!-- Bottom gradient -->
            <Rectangle width="1840" height="200" translation="[0,220]" color="0x05071099" />
            
            <!-- MOVIE badge (top right) -->
            <Group translation="[1700,20]">
                <Rectangle width="100" height="36" color="0x2E3192FF" />
                <Label translation="[15,6]" text="MOVIE" 
                    font="font:SmallBoldSystemFont" color="0xFFFFFFFF" />
            </Group>
            
            <!-- Hero content (bottom left) -->
            <Group translation="[40,260]">
                <Label id="heroTitle" width="1400" wrap="true" maxLines="2"
                    font="font:HugeBoldSystemFont" color="0xE8E8E8FF" />
                <Group translation="[0,70]">
                    <Label id="heroYear" width="80" 
                        font="font:MediumSystemFont" color="0xB3B3B3FF" />
                    <Label id="heroRating" translation="[90,0]" width="100" 
                        font="font:MediumBoldSystemFont" color="0xFF6B35FF" />
                    <Label id="heroGenre" translation="[180,0]" width="500" 
                        font="font:MediumSystemFont" color="0xB3B3B3FF" />
                </Group>
                <Label id="heroDescription" translation="[0,100]" width="800" 
                    wrap="true" maxLines="2"
                    font="font:MediumSystemFont" color="0x888888FF" />
            </Group>
        </Group>
        
        <!-- Movie rows by category -->
        <RowList id="movieGrid" translation="[40,480]" 
            itemComponentName="ContentItem" 
            numRows="2"
            itemSize="[160,240]" 
            itemSpacing="[16,30]"
            rowItemSize="[[160,240]]"
            rowItemSpacing="[[16,0]]"
            showRowLabel="[true]"
            rowLabelOffset="[[0,-45]]"
            rowLabelColor="0xE8E8E8FF"
            rowLabelFont="font:MediumBoldSystemFont"
            focusBitmapBlendColor="0x2E3192FF"
            visible="true" />
        
        <!-- Loading indicator -->
        <Group id="loadingGroup" translation="[860,480]">
            <BusySpinner id="spinner" translation="[0,0]" />
            <Label id="loadingLabel" translation="[-80,80]" text="Loading Movies..." 
                font="font:LargeBoldSystemFont" color="0xE8E8E8FF" />
        </Group>
        
        <!-- Error message -->
        <Label id="errorLabel" translation="[60,500]" width="1800" 
            font="font:MediumSystemFont" color="0xE53935FF" visible="false" />
        
        <!-- Category filter menu -->
        <Group id="categoryMenu" visible="false">
            <Rectangle width="1920" height="1080" color="0x000000EE" />
            <Rectangle translation="[660,50]" width="600" height="980" color="0x1a1a2eFF" />
            <Label translation="[700,90]" text="Categories" 
                font="font:LargeBoldSystemFont" color="0xE8E8E8FF" />
            <LabelList id="categoryList" translation="[700,160]" 
                itemSize="[520,50]" numRows="15" 
                color="0xB3B3B3FF"
                focusedColor="0xFFFFFFFF"
                focusBitmapBlendColor="0x2E3192FF" />
        </Group>
    </children>
</component>
