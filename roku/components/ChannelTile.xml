<?xml version="1.0" encoding="UTF-8"?>
<component name="ChannelTile" extends="Group">
    <interface>
        <field id="channel" type="assocarray" onChange="onChannelChange" />
        <field id="focused" type="boolean" value="false" onChange="onFocusChange" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/ChannelTile.brs" />

    <children>
        <!-- Tile background -->
        <Rectangle id="background" width="280" height="210" color="0x2a2a2aff" />

        <!-- Channel logo/thumbnail -->
        <Poster id="logo" width="280" height="180" />

        <!-- Channel title -->
        <Label id="title" translation="[10, 190]" width="260" height="20" 
            font="font:SmallSystemFont" color="0xffffffff" />

        <!-- Focus highlight -->
        <Rectangle id="focusRect" width="280" height="210" color="0x00000000" 
            strokeWidth="3" strokeColor="0xff6b00ff" visible="false" />
    </children>
</component>
