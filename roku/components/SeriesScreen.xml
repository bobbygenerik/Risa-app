<?xml version="1.0" encoding="utf-8"?>
<!-- SeriesScreen.xml - Series browsing screen with modern Netflix-style UI -->
<component name="SeriesScreen" extends="Group">
    <interface>
        <field id="visible" type="boolean" value="false" onChange="onVisibleChange" />
        <field id="xtreamServer" type="string" />
        <field id="xtreamUsername" type="string" />
        <field id="xtreamPassword" type="string" />
        <field id="seriesSelected" type="assocarray" alwaysNotify="true" />
        <field id="episodeSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesScreen.brs" />
    
    <children>
        <!-- Background gradient -->
        <Rectangle id="background" width="1920" height="1080" color="0x050710FF" />
        <Rectangle width="1920" height="540" translation="[0,540]" color="0x0d1140FF" />
        
        <!-- Hero section -->
        <Group id="heroSection" translation="[40,20]">
            <!-- Hero container -->
            <Rectangle id="heroBg" width="1840" height="420" color="0x1a1a2eFF" />
            
            <!-- Hero background image -->
            <Poster id="heroImage" width="1840" height="420" loadDisplayMode="scaleToZoom" />
            
            <!-- Dark overlay -->
            <Rectangle width="1840" height="420" color="0x00000066" />
            
            <!-- Bottom gradient -->
            <Rectangle width="1840" height="200" translation="[0,220]" color="0x05071099" />
            
            <!-- SERIES badge (top right) -->
            <Group translation="[1700,20]">
                <Rectangle width="100" height="36" color="0x4CAF50FF" />
                <Label translation="[12,6]" text="SERIES" 
                    font="font:SmallBoldSystemFont" color="0xFFFFFFFF" />
            </Group>
            
            <!-- Hero content (bottom left) -->
            <Group translation="[40,260]">
                <Label id="heroTitle" width="1400" wrap="true" maxLines="2"
                    font="font:HugeBoldSystemFont" color="0xE8E8E8FF" />
                <Group translation="[0,70]">
                    <Label id="heroYear" width="80" 
                        font="font:MediumSystemFont" color="0xB3B3B3FF" />
                    <Label id="heroRating" translation="[90,0]" width="100" 
                        font="font:MediumBoldSystemFont" color="0xFF6B35FF" />
                    <Label id="heroGenre" translation="[180,0]" width="500" 
                        font="font:MediumSystemFont" color="0xB3B3B3FF" />
                </Group>
                <Label id="heroSeasons" translation="[0,100]" width="300" 
                    font="font:MediumSystemFont" color="0x888888FF" />
            </Group>
        </Group>
        
        <!-- Series rows by category -->
        <RowList id="seriesGrid" translation="[40,480]" 
            itemComponentName="ContentItem" 
            numRows="2"
            itemSize="[160,240]" 
            itemSpacing="[16,30]"
            rowItemSize="[[160,240]]"
            rowItemSpacing="[[16,0]]"
            showRowLabel="[true]"
            rowLabelOffset="[[0,-45]]"
            rowLabelColor="0xE8E8E8FF"
            rowLabelFont="font:MediumBoldSystemFont"
            focusBitmapBlendColor="0x2E3192FF"
            visible="true" />
        
        <!-- Loading indicator -->
        <Group id="loadingGroup" translation="[860,480]">
            <BusySpinner id="spinner" translation="[0,0]" />
            <Label id="loadingLabel" translation="[-80,80]" text="Loading Series..." 
                font="font:LargeBoldSystemFont" color="0xE8E8E8FF" />
        </Group>
        
        <!-- Error message -->
        <Label id="errorLabel" translation="[60,500]" width="1800" 
            font="font:MediumSystemFont" color="0xE53935FF" visible="false" />
        
        <!-- Category filter menu -->
        <Group id="categoryMenu" visible="false">
            <Rectangle width="1920" height="1080" color="0x000000EE" />
            <Rectangle translation="[660,50]" width="600" height="980" color="0x1a1a2eFF" />
            <Label translation="[700,90]" text="Categories" 
                font="font:LargeBoldSystemFont" color="0xE8E8E8FF" />
            <LabelList id="categoryList" translation="[700,160]" 
                itemSize="[520,50]" numRows="15" 
                color="0xB3B3B3FF"
                focusedColor="0xFFFFFFFF"
                focusBitmapBlendColor="0x2E3192FF" />
        </Group>
        
        <!-- Series detail view (seasons/episodes) -->
        <Group id="detailView" visible="false">
            <Rectangle width="1920" height="1080" color="0x050710FF" />
            <Rectangle width="1920" height="540" translation="[0,540]" color="0x0d1140FF" />
            
            <!-- Series info header -->
            <Group id="detailHeader" translation="[0,0]">
                <Poster id="detailBackdrop" width="1920" height="500" loadDisplayMode="scaleToZoom" />
                <Rectangle width="1920" height="500" color="0x00000088" />
                
                <Poster id="detailPoster" translation="[60,120]" width="200" height="300" loadDisplayMode="scaleToZoom" />
                <Label id="detailTitle" translation="[300,140]" width="1500" 
                    font="font:HugeBoldSystemFont" color="0xE8E8E8FF" />
                <Label id="detailMeta" translation="[300,210]" width="1500" 
                    font="font:MediumSystemFont" color="0xB3B3B3FF" />
                <Label id="detailPlot" translation="[300,260]" width="1500" height="160" 
                    font="font:SmallSystemFont" color="0x888888FF" wrap="true" maxLines="5" />
            </Group>
            
            <!-- Season selector -->
            <LabelList id="seasonList" translation="[60,520]" 
                itemSize="[150,50]" numRows="1" 
                color="0xB3B3B3FF"
                focusedColor="0xFFFFFFFF"
                focusBitmapBlendColor="0x2E3192FF" />
            
            <!-- Episode list -->
            <RowList id="episodeGrid" translation="[60,600]" 
                itemComponentName="ContentItem" 
                numRows="2"
                itemSize="[280,160]" 
                itemSpacing="[16,20]"
                rowItemSize="[[280,160]]"
                rowItemSpacing="[[16,0]]"
                focusBitmapBlendColor="0x2E3192FF"
                showRowLabel="[false]" />
        </Group>
    </children>
</component>
