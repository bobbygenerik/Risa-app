<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:background="?android:attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="@dimen/4pt"
    android:minHeight="@dimen/6fb"
    android:layoutDirection="locale">
    <ImageView
        android:id="@+id/5d4"
        android:layout_width="@dimen/6qt"
        android:layout_height="@dimen/6qt"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="8dp"/>
    <LinearLayout
        android:gravity="start|center_vertical"
        android:orientation="vertical"
        android:paddingRight="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2dp"
        android:layout_marginRight="2dp"
        android:minHeight="@dimen/6fb"
        android:layoutDirection="locale"
        android:paddingEnd="4dp">
        <TextView
            android:textSize="@dimen/4jm"
            android:textColor="@color/4sa"
            android:id="@+id/mf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textDirection="locale"/>
        <TextView
            android:textSize="@dimen/5ep"
            android:textColor="@color/167"
            android:id="@+id/1bj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textDirection="locale"/>
    </LinearLayout>
</LinearLayout>
