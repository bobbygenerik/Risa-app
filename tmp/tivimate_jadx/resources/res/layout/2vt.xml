<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/2h0"
    android:background="?android:attr/selectableItemBackground"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd">
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:id="@+id/1o3"
        android:duplicateParentState="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@android:id/icon"
            android:layout_width="@dimen/5go"
            android:layout_height="@dimen/5go"
            android:layout_marginEnd="@dimen/5i9"
            style="?android:attr/imageButtonStyle"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:duplicateParentState="true"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <Space
            android:layout_width="0dp"
            android:layout_height="@dimen/j4"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceListItem"
            android:id="@android:id/title"
            android:duplicateParentState="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/3f4"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceListItemSecondary"
            android:id="@android:id/summary"
            android:duplicateParentState="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="4"/>
        <Space
            android:layout_width="0dp"
            android:layout_height="@dimen/17o"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@android:id/widget_frame"
        android:duplicateParentState="true"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"/>
</LinearLayout>
